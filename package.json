{
  "name": "rwa-cli",
  "version": "0.2.0",
  "description": "CLI for tokenized real-world asset market discovery and quotes across venues.",
  "type": "module",
  "files": [
    "src",
    "skills",
    ".claude-plugin",
    "AGENT.md",
    "README.md"
  ],
  "bin": {
    "rwa": "src/cli.js"
  },
  "exports": {
    ".": "./src/export/supabase-snapshot.js",
    "./snapshot": "./src/export/supabase-snapshot.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test",
    "verify:data": "node scripts/verify-data.js",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm test"
  },
  "keywords": [
    "rwa",
    "cli",
    "tokenized-assets",
    "stocks",
    "commodities"
  ],
  "preferGlobal": true,
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "ws": "^8.18.3"
  }
}
